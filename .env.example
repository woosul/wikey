# wikey 클라우드 API 키 설정
# 이 파일을 .env로 복사한 후 실제 키를 입력하세요.
# .env는 git에 포함되지 않습니다.

# Google Gemini — 대용량 소스 요약 (summarize-large-source.sh)
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI — Codex CLI 교차 검증 (선택)
OPENAI_API_KEY=

# Anthropic — Claude API 직접 호출 (선택, Claude Code와 별도)
ANTHROPIC_API_KEY=
