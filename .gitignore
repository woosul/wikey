# Raw sources (PII protection)
raw/

# Wiki content (사용자 ingest 산출물 — 개인 자료, 공개 리포에 노출 금지)
wiki/

# .wikey/ vault state — 사용자 vault 별 dynamic, git 충돌 방지
# source-registry.json 은 historic tracked → 유지. 나머지 ignore.
.wikey/mention-history.json
.wikey/suggestions.json
.wikey/converged-decompositions.json
.wikey/converged-decompositions.mock-baseline.json
.wikey/qmd-embeddings.json
# (converged-decompositions.json 도 사용자 vault dynamic state — git 충돌 방지)
.wikey/self-declarations.json
.wikey/schema.yaml

# Obsidian Web Clipper 기본 저장 폴더 — 개인 수집 자료, 공개 리포에 노출 금지
Clippings/

# Obsidian (UI 상태 — 사용자마다 다름)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json

# Local LLM models
local-llm/*.gguf
local-llm/*.bin

# API keys
.env

# OS
.DS_Store
Thumbs.db

# Temp
/tmp/
*.tmp

# Python
__pycache__/
*.pyc

# Tools — qmd (source clone, node_modules excluded)
tools/qmd/node_modules/

# Node.js
node_modules/

# wikey-core build output + coverage
wikey-core/dist/
wikey-core/coverage/

# wikey-obsidian build output
wikey-obsidian/main.js

# Obsidian plugin data (사용자별 설정)
.obsidian/plugins/wikey/data.json
.obsidian/*.bak

# Claude Code session
.claude/settings.local.json
.claude/scheduled_tasks.lock
.venv-smoke/
